          "type": "select",
          "required": true,
          "code": "climbed",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "Hub": "Hub",
            "Depot": "Depot",
            "Outpost": "Outpost",
            "Tren": "Trench",
            "Other": "Other spots (middle area of field)"
          }
        },
        {
          "title": "Role of Robot during the Active shift?",
          "description": "What did the robot mainly do during this Active period?",
          "type": "select",
          "required": true,
          "code": "climbed",
          "formResetBehavior": "reset",
          "defaultValue": "None",
          "choices": {
            "No Role": "None",
            "Score": "Scorer",
            "Shoot": "Shooter",
            "Shuttle": "Shuttler",
            "Pass": "Passer",
            "Defend": "Defender"
          }
        }
      ]
    },
    {

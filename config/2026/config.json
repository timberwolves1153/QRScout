          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Role of Robot during Inactive Shift?",
          "description": "What did the robot mainly do during this Active period?",
          "type": "select",
          "required": true,
          "code": "climbed",
          "formResetBehavior": "reset",
          "defaultValue": "None",
          "choices": {
            "No Role": "None",
            "Score": "Scorer",
            "Shoot": "Shooter",
            "Shuttle": "Shuttler",
            "Pass": "Passer",
            "Defend": "Defender"
          }
        },
        {
          "title": "Defended during Inactive Shift?",
          "description": "Did the robot play defense during the match?",
          "type": "boolean",
          "required": false,
          "code": "robotDefended",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Gold Spot during Inactive Shift?",
          "description": "Where did the robot score/corral all of the balls to during the match?",
          "type": "select",
          "required": true,
          "code": "climbed",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "Hub": "Hub",
            "Depot": "Depot",
            "Outpost": "Outpost",
            "Tren": "Trench",
            "Other": "Other spots (middle area of field)"
          }
        }
      ]
    },
    {
      "name": "Endgame",
      "fields": [
        {
          "title": "Climbed",
          "description": "The level the robot climbed during endgame.",
          "type": "select",
          "required": true,
          "code": "climbed",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "No": "No Climb",
            "L1": "Level 1",
            "L2": "Level 2",
            "L3": "Level 3",
            "F": "Failed Climb"
          }
        },
        {
          "title": "Where Climbed",
          "description": "Where on the tower did the robot climb?",
          "type": "select",
          "required": false,
          "code": "climbPos",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "No": "No Climb",
            "Out": "Output Side",
            "Mid": "Middle",
            "Dep": "Depot Side"
          }
        }
      ]
    },
    {
      "name": "Postmatch",
      "fields": [
        {
          "title": "Mechanical Issue?",
          "description": "Did the robot have a mechanical issue during the match?",
          "type": "boolean",
          "required": false,
          "code": "mechIssue",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Died?",
          "description": "Did the robot die during the match?",
          "type": "boolean",
          "required": false,
          "code": "died",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Tipped/Fell Over",
          "description": "Did the robot tip or fall over during the match?",
          "type": "boolean",
          "required": false,
          "code": "tipped",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Scoring Effectiveness",
          "description": "Rate the robot's scoring effectiveness.",
          "type": "range",
          "required": false,
          "code": "scoringEff",
          "formResetBehavior": "reset",
          "defaultValue": 3,
          "min": 0,
          "max": 5,
          "step": 1
        },
        {
          "title": "Robot Overall Performance?",
          "description": "How did the robot perform as a whole during the match?",
          "type": "select",
          "required": false,
          "code": "OverallPerformance",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "1": "While driving",
            "2": "While stationary",
            "3": "Both",
            "4": "No scoring",
            "5": "No scoring"
          }
        },
        {
          "title": "Passing Skill",
          "description": "Rate the robot's passing skill.",
          "type": "range",
          "required": false,
          "code": "passingSkill",
          "formResetBehavior": "reset",
          "defaultValue": 3,
          "min": 0,
          "max": 5,
          "step": 1
        },
        {
          "title": "Passed How?",
          "description": "How did the robot pass?",
          "type": "select",
          "required": false,
          "code": "passedHow",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "driving": "While driving",
            "stationary": "While stationary",
            "both": "Both",
            "none": "No Passing"
          }
        },
        {
          "title": "Passing Location?",
          "description": "Where did the robot pass?",
          "type": "select",
          "required": false,
          "code": "passLoc",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "scattered": "Scattered",
            "intentional": "Intentional",
            "both": "Both",
            "none": "No passing"
          }
        },
        {
          "title": "Defense Skill",
          "description": "Rate the robot's defensive skill.",
          "type": "range",
          "required": false,
          "code": "defSkill",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "max": 5,
          "step": 1
        },
        {
          "title": "Yellow/Red Card",
          "type": "select",
          "required": true,
          "code": "yc",
          "formResetBehavior": "reset",
          "defaultValue": "No Card",
          "choices": {
            "No Card": "No Card",
            "Yellow": "Yellow Card",
            "Red": "Red Card"
          }
        },
        {
          "title": "Comments",
          "type": "text",
          "required": false,
          "code": "co",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "min": 0,
          "max": 100
        }
      ]
    }
